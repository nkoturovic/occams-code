#!/usr/bin/env bash
#
# oc - OpenCode launcher
#
# Usage:
#   oc                    Interactive: pick preset (first run), session, launch
#   oc --quick            Skip prompts, use project/global config directly
#   oc --no-init          Skip project config setup and workspace init
#   oc --preset cheap     Set preset (writes project config), launch
#   oc --doctor           Run diagnostics (config, wiki, lint)
#   oc --sync-profile     Regenerate config from model-profile.jsonc
#   oc --init-project     Create project wiki page + AGENTS.md
#   oc --ingest-repo URL  Snapshot GitHub repo into wiki
#   oc -c                 Continue last session
#

# --- Bash version gate (requires 4.0+) ---
if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
  echo "Error: occams-code requires bash 4.0+." >&2
  echo "  macOS: brew install bash && use /opt/homebrew/bin/bash or /usr/local/bin/bash" >&2
  echo "  Linux: your default bash is likely fine" >&2
  exit 1
fi

set -euo pipefail

CONFIG="$HOME/.config/opencode/oh-my-opencode-slim.json"
CORE_CONFIG="$HOME/.config/opencode/opencode.json"
STATE_DIR="$HOME/.local/state/opencode"
# Override 32K output token cap — match model capabilities not a one-size-fits-all floor
export OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX=131072

# Resolve project config: prefer .jsonc, fall back to .json (matches omo-slim behavior)
PROJECT_CONFIG=""
for _pc in ".opencode/oh-my-opencode-slim.jsonc" ".opencode/oh-my-opencode-slim.json"; do
  if [[ -f "$_pc" ]]; then PROJECT_CONFIG="$_pc"; break; fi
done
# Default path for new file creation (use .jsonc)
PROJECT_CONFIG_NEW=".opencode/oh-my-opencode-slim.jsonc"

BOLD='\033[1m'; DIM='\033[2m'; CYAN='\033[36m'; GREEN='\033[32m'
YELLOW='\033[33m'; RED='\033[31m'; RESET='\033[0m'

# --- Dependency check ---
if ! command -v jq &>/dev/null; then
  echo -e "${RED}Error: jq is required.${RESET}" >&2; exit 1
fi
if [[ ! -f "$CONFIG" ]]; then
  echo -e "${RED}Error: Config not found: $CONFIG${RESET}" >&2; exit 1
fi

# --- Parse arguments ---
QUICK=false; PRESET_ARG=""; INIT_PROJECT=false; DOCTOR=false
INGEST_REPO=""; SAFE=false; UNSAFE=false; SYNC_PROFILE=false; NO_INIT=false; OPENCODE_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --quick|-q)    QUICK=true; shift ;;
    --no-init|-n)  NO_INIT=true; shift ;;
    --preset|-p)   PRESET_ARG="$2"; shift 2 ;;
    --sync-profile) SYNC_PROFILE=true; shift ;;
    --safe)        SAFE=true; shift ;;
    --unsafe)      UNSAFE=true; shift ;;
    --init-project) INIT_PROJECT=true; shift ;;
    --doctor)      DOCTOR=true; shift ;;
    --ingest-repo) INGEST_REPO="$2"; shift 2 ;;
    --help|-h)
      echo "oc - OpenCode launcher"
      echo ""
      echo "Usage:"
      echo "  oc                    Interactive launch (first run picks preset)"
      echo "  oc --quick            Skip prompts, use project/global config"
      echo "  oc --no-init          Skip project config setup and workspace init"
      echo "  oc --preset <name>    Set preset, create project config, launch"
      echo "  oc --doctor           Run diagnostics (config, wiki, lint)"
      echo "  oc --sync-profile     Regenerate config from model-profile.jsonc"
      echo "  oc --init-project     Create project wiki page + AGENTS.md"
      echo "  oc --ingest-repo URL  Snapshot GitHub repo into wiki"
      echo "  oc --safe             Permission prompts for this session"
      echo "  oc --unsafe           Auto-approve all for this session"
      echo "  oc -c                 Continue last session"
      exit 0 ;;
    *) OPENCODE_ARGS+=("$1"); shift ;;
  esac
done

# Early validation
[[ "$SAFE" == true && "$UNSAFE" == true ]] \
  && { echo -e "${RED}--safe and --unsafe are mutually exclusive.${RESET}" >&2; exit 1; }

# --- Helpers ---
is_interactive() { [[ -t 0 && -t 1 ]]; }

# Detect directories that are likely temporary/scratch
is_ephemeral_dir() {
  case "$PWD" in
    /tmp/*|/var/tmp/*) return 0 ;;
  esac
  local base="${PWD##*/}"
  [[ "$base" =~ ^(tmp|temp|scratch|dummy|test|playground|sandbox)([-_].*)?$ ]]
}

# Detect common project root markers
has_project_markers() {
  [[ -d ".git" ]] ||
  [[ -f "package.json" ]] ||
  [[ -f "pyproject.toml" ]] ||
  [[ -f "Cargo.toml" ]] ||
  [[ -f "go.mod" ]] ||
  [[ -f "CMakeLists.txt" ]] ||
  [[ -f "flake.nix" ]]
}

# Check if directory is empty or only contains .opencode/
is_empty_or_config_only() {
  local files
  files=$(find . -maxdepth 1 -not -path '.' -not -path './.opencode' 2>/dev/null | wc -l)
  [[ "$files" -eq 0 ]]
}

has_sessions() {
  [[ -f "$HOME/.local/share/opencode/opencode.db" ]] || return 1
  python3 - "$HOME/.local/share/opencode/opencode.db" "$(pwd)" <<'PY'
import sqlite3, sys
db, cwd = sys.argv[1], sys.argv[2]
try:
    conn = sqlite3.connect(db)
    row = conn.execute("SELECT 1 FROM session WHERE directory=? LIMIT 1", (cwd,)).fetchone()
    sys.exit(0 if row else 1)
except Exception:
    sys.exit(1)
PY
}

show_config() {
  local preset model_count source="global"
  if [[ -n "$PROJECT_CONFIG" ]]; then
    local oc_p
    oc_p=$(jq -r '.preset // empty' <(sed '/^\s*\/\//d; s/\/\/.*$//' "$PROJECT_CONFIG") 2>/dev/null) || true
    if [[ -n "$oc_p" ]]; then
      preset="$oc_p"
      source="project"
    fi
  fi
  if [[ -z "${preset:-}" ]]; then
    preset=$(jq -r '.preset' "$CONFIG")
  fi
  # Guard: fall back to global default if preset not found
  if ! jq --arg p "$preset" -e '.presets[$p]' "$CONFIG" >/dev/null 2>&1; then
    echo -e "${YELLOW}Warning: preset '$preset' not found, falling back to global default${RESET}"
    preset=$(jq -r '.preset' "$CONFIG")
    source="global (fallback)"
  fi
  model_count=$(jq --arg p "$preset" -r '.presets[$p] | length' "$CONFIG")
  echo -e "${BOLD}Preset: ${CYAN}$preset${RESET} ${DIM}($model_count agents, $source)${RESET}"
  if [[ -n "$PROJECT_CONFIG" ]] && jq -e '.agents' <(sed '/^\s*\/\//d; s/\/\/.*$//' "$PROJECT_CONFIG") >/dev/null 2>&1; then
    jq -r --slurpfile proj <(sed '/^\s*\/\//d; s/\/\/.*$//' "$PROJECT_CONFIG") --arg p "$preset" '
      .presets[$p] | to_entries | map(
        .key as $k | .value.model as $default |
        (($proj[0].agents[$k].model // $default)) as $model |
        (if $proj[0].agents[$k].model then " ← override" else "" end) as $tag |
        "\($k)\t\($model)\($tag)"
      ) | .[]
    ' "$CONFIG" | column -t -s $'\t'
  else
    jq --arg p "$preset" -r '.presets[$p] | to_entries[] | "  \(.key)\t\(.value.model)"' "$CONFIG" \
      | column -t -s $'\t'
  fi
}

# --- Set preset (--preset flag) ---
set_preset() {
  local preset="$1"
  if ! jq --arg p "$preset" -e '.presets[$p]' "$CONFIG" >/dev/null 2>&1; then
    echo -e "${RED}Preset '$preset' not found.${RESET}" >&2
    echo "Available: $(jq -r '.presets | keys | join(", ")' "$CONFIG")" >&2
    exit 1
  fi
  mkdir -p .opencode
  # Merge: preserve existing fields, only set/overwrite preset
  if [[ -n "$PROJECT_CONFIG" ]]; then
    local merged
    merged=$(jq --arg p "$preset" '.preset = $p' <(sed '/^\s*\/\//d; s/\/\/.*$//' "$PROJECT_CONFIG"))
    printf '%s\n' "$merged" > "$PROJECT_CONFIG"
  else
    printf '{"preset":"%s"}\n' "$preset" > "$PROJECT_CONFIG_NEW"
    PROJECT_CONFIG="$PROJECT_CONFIG_NEW"
  fi
  echo -e "${GREEN}Set preset: $preset${RESET}"
}

# --- First-run: create project config if missing ---
first_run_setup() {
  is_interactive || return 0
  [[ -n "$PROJECT_CONFIG" ]] && return 0

  local current_preset presets
  current_preset=$(jq -r '.preset' "$CONFIG")
  presets=$(jq -r '.presets | keys[]' "$CONFIG")

  local i=1 default_num=1 total
  total=$(echo "$presets" | wc -l)
  echo -e "${BOLD}No project config. Select preset:${RESET}"
  while IFS= read -r p; do
    if [[ "$p" == "$current_preset" ]]; then
      echo -e "  ${GREEN}$i) $p${RESET} ${DIM}(default)${RESET}"
      default_num=$i
    else
      echo "  $i) $p"
    fi
    ((i++))
  done <<< "$presets"

  local selected="$current_preset"
  while true; do
    read -r -p "$(echo -e "${BOLD}Select [${default_num}]:${RESET} ")" input
    input="${input:-$default_num}"
    if [[ "$input" =~ ^[0-9]+$ ]] && [ "$input" -ge 1 ] && [ "$input" -le "$total" ]; then
      selected=$(echo "$presets" | sed -n "${input}p")
      break
    fi
    echo -e "${YELLOW}Enter 1-${total}${RESET}"
  done

  mkdir -p .opencode
  jq -n --arg p "$selected" '{"preset":$p}' > "$PROJECT_CONFIG_NEW"
  PROJECT_CONFIG="$PROJECT_CONFIG_NEW"
  echo -e "${GREEN}Created $PROJECT_CONFIG (preset: $selected)${RESET}"
}

# --- Session mode ---
ask_session_mode() {
  local arg
  for arg in "${OPENCODE_ARGS[@]+"${OPENCODE_ARGS[@]}"}"; do
    case "$arg" in -c|--continue|--session|--fork) return ;; esac
  done
  is_interactive || return 0
  has_sessions || return 0
  local choice
  read -r -p "$(echo -e "${BOLD}Session (1=New, 2=Continue) [1]:${RESET} ")" choice
  [[ "${choice:-1}" == "1" || "$choice" == "n" ]] || OPENCODE_ARGS+=("-c")
}

# --- Standalone: doctor (config + wiki + lint) ---
run_doctor() {
  local status=0
  echo -e "${BOLD}Doctor${RESET}"; echo ""

  # Global config
  if jq empty "$CONFIG" 2>/dev/null; then
    local preset model_count
    preset=$(jq -r '.preset' "$CONFIG")
    model_count=$(jq --arg p "$preset" -r '.presets[$p] | length' "$CONFIG")
    echo -e "  ${GREEN}✓${RESET} Global config (preset: $preset, $model_count agents)"
  else
    echo -e "  ${RED}✗${RESET} Global config invalid JSON"; status=1
  fi

  # Project config
  if [[ -n "$PROJECT_CONFIG" ]]; then
    local oc_p
    oc_p=$(jq -r '.preset // "—"' <(sed '/^\s*\/\//d; s/\/\/.*$//' "$PROJECT_CONFIG") 2>/dev/null)
    echo -e "  ${GREEN}✓${RESET} Project config: $PROJECT_CONFIG (preset: $oc_p)"
  else
    echo -e "  ${DIM}  No project config (using global)${RESET}"
  fi

  # Wiki structure
  if [[ -f "$HOME/.agents/wiki/AGENTS.md" && -f "$HOME/.agents/wiki/index.md" && -d "$HOME/.agents/wiki/raw" && -d "$HOME/.agents/wiki/concepts" ]]; then
    echo -e "  ${GREEN}✓${RESET} Wiki structure"
  else
    echo -e "  ${YELLOW}⚠${RESET} Wiki structure incomplete"; status=1
  fi

  # Wiki index
  local index_lines
  index_lines=$(grep -c '^\- \[\[' "$HOME/.agents/wiki/index.md" 2>/dev/null || echo 0)
  if [[ "$index_lines" -ge 3 ]]; then
    echo -e "  ${GREEN}✓${RESET} Wiki index ($index_lines entries)"
  else
    echo -e "  ${YELLOW}⚠${RESET} Wiki index sparse ($index_lines entries)"; status=1
  fi

  # Wiki lint
  if command -v python3 &>/dev/null && [[ -f "$HOME/.agents/scripts/wiki-lint.py" ]]; then
    echo ""
    python3 "$HOME/.agents/scripts/wiki-lint.py" || true
  fi

  # Model config validation (opencode.json + slim.json integrity)
  if command -v python3 &>/dev/null && [[ -f "$HOME/.config/opencode/scripts/doctor-model-check.py" ]]; then
    echo ""
    python3 "$HOME/.config/opencode/scripts/doctor-model-check.py" \
      --core-config "$CORE_CONFIG" \
      --slim-config "$CONFIG" \
      --auth-config "$HOME/.local/share/opencode/auth.json" || status=1
  fi

  echo ""
  [[ "$status" -eq 0 ]] && echo -e "${GREEN}All good.${RESET}" \
                         || echo -e "${YELLOW}Some checks need attention.${RESET}"
  return "$status"
}

# --- Standalone: project init ---
run_project_init() {
  local init_script="$HOME/.agents/scripts/project-init.py"
  if [[ ! -f "$init_script" ]]; then
    init_script="$HOME/.config/opencode/scripts/project-init.py"
  fi
  if ! command -v python3 &>/dev/null || [[ ! -f "$init_script" ]]; then
    echo -e "${YELLOW}⚠ project-init.py not found${RESET}"; return 1
  fi
  python3 "$init_script" --project-path "$PWD"
}

# --- Standalone: sync models from model-profile ---
run_sync_profile() {
  local map_file="$HOME/.config/opencode/model-profile.jsonc"
  if [[ ! -f "$map_file" ]]; then
    echo -e "${YELLOW}~/.config/opencode/model-profile.jsonc not found. Create it first.${RESET}"
    echo "  See: ~/.agents/wiki/concepts/model-profile-guide.md"
    return 1
  fi
  python3 "$HOME/.config/opencode/scripts/model-profile.py" "$map_file" "$CONFIG"
  echo -e "${GREEN}✓ Config regenerated from model-profile.jsonc${RESET}"
}

# --- Permission management ---
launch_with_permissions() {
  local mode="$1" perm_backup="$STATE_DIR/oc-perm-backup-$(id -u)-$$"
  mkdir -p "$STATE_DIR"

  # Save + apply
  python3 - "$CORE_CONFIG" "$perm_backup" "$mode" <<'PY'
import json, sys
from pathlib import Path
c, b, m = Path(sys.argv[1]), Path(sys.argv[2]), sys.argv[3]
cfg = json.loads(c.read_text())
b.write_text(json.dumps({"h": "permission" in cfg, "v": cfg.get("permission")}))
if m == "unsafe": cfg["permission"] = "allow"
else: cfg.pop("permission", None)
c.write_text(json.dumps(cfg, indent=2) + "\n")
PY

  restore() {
    python3 - "$CORE_CONFIG" "$perm_backup" <<'PY'
import json, sys
from pathlib import Path
c, b = Path(sys.argv[1]), Path(sys.argv[2])
if not b.exists(): raise SystemExit(0)
cfg, bk = json.loads(c.read_text()), json.loads(b.read_text())
if bk["h"]: cfg["permission"] = bk["v"]
else: cfg.pop("permission", None)
c.write_text(json.dumps(cfg, indent=2) + "\n")
PY
    rm -f "$perm_backup"
  }

  trap restore EXIT INT TERM
  [[ "$mode" == "unsafe" ]] && echo -e "${YELLOW}⚠ Unsafe mode${RESET}" \
                            || echo -e "${YELLOW}⚠ Safe mode${RESET}"
  opencode "${OPENCODE_ARGS[@]+"${OPENCODE_ARGS[@]}"}"
  local rc=$?
  restore; trap - EXIT INT TERM; return $rc
}

# --- Auto-initialize project workspace ---
maybe_auto_init() {
  # Skip if explicitly disabled
  [[ "$NO_INIT" == true ]] && return 0
  # Need a project config to consider this a managed project
  [[ -n "$PROJECT_CONFIG" ]] || return 0
  # Already initialized — skip
  [[ -f "AGENTS.md" ]] && return 0
  # Don't init in home directory
  [[ "$PWD" == "$HOME" ]] && return 0
  # Non-interactive: skip auto-init to avoid unwanted side effects
  is_interactive || return 0

  # Determine default based on directory characteristics
  local default_answer="n" prompt_suffix=""
  if has_project_markers; then
    default_answer="y"
    prompt_suffix=" (project markers detected)"
  elif is_ephemeral_dir || is_empty_or_config_only; then
    default_answer="n"
    prompt_suffix=""
  fi

  echo ""
  echo -e "${YELLOW}Project workspace not initialized.${RESET}"
  echo -e "  ${DIM}Path: $PWD${RESET}"
  echo -e "  ${DIM}Creates: AGENTS.md, .agents/, global wiki project page${RESET}"
  local answer
  read -r -p "$(echo -e "${BOLD}Initialize project workspace? [${default_answer}]${prompt_suffix}:${RESET} ")" answer
  answer="${answer:-$default_answer}"
  [[ "$answer" =~ ^[Yy]$ ]] || return 0

  # Find the init script (prefer universal, fallback to OpenCode-specific)
  local init_script="$HOME/.agents/scripts/project-init.py"
  [[ -f "$init_script" ]] || init_script="$HOME/.config/opencode/scripts/project-init.py"
  [[ -f "$init_script" ]] || return 0
  command -v python3 &>/dev/null || return 0
  echo -e "${DIM}  Initializing project workspace...${RESET}"
  python3 "$init_script" --project-path "$PWD" --quiet 2>&1 | sed 's/^/  /'
}

# --- Main ---
main() {
  # Standalone commands: skip everything, run, exit
  if [[ -n "$INGEST_REPO" ]]; then
    python3 "$HOME/.agents/scripts/repo-ingest.py" "$INGEST_REPO" \
      && echo -e "${GREEN}✓ Ingested${RESET}" || exit 1
    exit 0
  fi
  [[ "$DOCTOR" == true ]] && { run_doctor; exit $?; }
  [[ "$SYNC_PROFILE" == true ]] && { run_sync_profile; exit $?; }
  [[ "$INIT_PROJECT" == true ]] && { run_project_init; exit $?; }

  # Verify opencode is available before interactive prompts.
  if ! command -v opencode &>/dev/null; then
    echo -e "${RED}Error: opencode not found in PATH.${RESET}" >&2
    echo "  Install OpenCode first: https://opencode.ai/docs/install" >&2
    echo "  Or if already installed, ensure it's in your PATH." >&2
    exit 1
  fi

  # Crash recovery (before any output)
  local _pb
  for _pb in "$STATE_DIR/oc-perm-backup-$(id -u)-"*; do
    [[ -f "$_pb" ]] || break
    echo -e "${YELLOW}⚠ Recovering permissions from crash...${RESET}"
    python3 - "$CORE_CONFIG" "$_pb" <<'PY'
import json, sys
from pathlib import Path
c, b = Path(sys.argv[1]), Path(sys.argv[2])
if not b.exists(): raise SystemExit(0)
cfg, bk = json.loads(c.read_text()), json.loads(b.read_text())
if bk["h"]: cfg["permission"] = bk["v"]
else: cfg.pop("permission", None)
c.write_text(json.dumps(cfg, indent=2) + "\n")
PY
    rm -f "$_pb"
  done

  local show_banner=false
  is_interactive && [[ "$QUICK" == false ]] && show_banner=true

  # --preset flag: merge into project config
  if [[ -n "$PRESET_ARG" ]]; then
    set_preset "$PRESET_ARG"
  fi

  # First-run setup (before show_config, so config reflects the final state)
  [[ "$QUICK" == false && "$NO_INIT" == false ]] && first_run_setup || true

  # Auto-initialize project workspace (after preset selection)
  maybe_auto_init

  # Banner + config (interactive, non-quick only)
  if [[ "$show_banner" == true ]]; then
    echo ""
    echo -e "${BOLD}${CYAN}  OpenCode${RESET}"
    echo -e "${DIM}  ───────${RESET}"
    echo ""
    show_config
    echo ""
  fi

  # Session choice (skip if --quick, --preset, or continuing)
  if [[ -z "$PRESET_ARG" && "$QUICK" == false ]]; then
    local continuing=false
    for a in "${OPENCODE_ARGS[@]+"${OPENCODE_ARGS[@]}"}"; do
      case "$a" in -c|--continue|--session|--fork) continuing=true ;; esac
    done
    [[ "$continuing" == false ]] && ask_session_mode || true
  fi

  # Launch — strip -c if no sessions exist (prevents black screen)
  if ! has_sessions; then
    local _filtered=()
    for a in "${OPENCODE_ARGS[@]+"${OPENCODE_ARGS[@]}"}"; do
      [[ "$a" != "-c" && "$a" != "--continue" ]] && _filtered+=("$a")
    done
    OPENCODE_ARGS=("${_filtered[@]+"${_filtered[@]}"}")
  fi
  # Tmux multiplexer: inject --port so subagent panes can attach
  # Required by omo-slim multiplexer (workaround for opencode#9099)
  # --port 0: tries 4096 first (backward compatible), auto-assigns if taken.
  # The real port is passed to subagent panes via Server.url (not env var).
  # This avoids silent hangs when running multiple opencode instances
  # across different tmux sessions/windows/panes on the same machine.
  if [[ -n "${TMUX:-}" ]]; then
    OPENCODE_ARGS+=("--port" "0")
  fi

  if [[ "$SAFE" == true || "$UNSAFE" == true ]] && [[ -f "$CORE_CONFIG" ]]; then
    [[ "$show_banner" == false ]] && echo "" # spacing for non-interactive
    launch_with_permissions "$([[ "$UNSAFE" == true ]] && echo unsafe || echo safe)"
  else
    [[ "$show_banner" == true ]] && echo -e "${DIM}Launching...${RESET}" && echo ""
    exec opencode "${OPENCODE_ARGS[@]+"${OPENCODE_ARGS[@]}"}"
  fi
}

main
