# Occam's Code — shared API secrets
#
# This file holds API keys as environment variables. Sourced from ~/.profile
# (so they're available to BOTH bash and zsh, login + interactive shells, and
# any script you launch — analyze-video.py, transcribe, MCP servers, etc.).
#
# Setup:
#   1. Copy this template:        cp config/secrets-env.example ~/.config/secrets/env
#   2. Fill in your real keys (uncomment the lines below)
#   3. Tighten permissions:       chmod 600 ~/.config/secrets/env
#   4. Reload shell:              source ~/.profile  (or open a new terminal)
#
# The repo's `scripts/install.sh` does all of this for you interactively.
#
# This file is for SCRIPT-VISIBLE secrets. OpenCode itself reads its own
# auth.json at ~/.local/share/opencode/auth.json (a separate JSON file).
# Both can hold the same keys — `install.sh` will set up either or both.

# ── LLM provider API keys ─────────────────────────────────────────────
# Recommended default: OpenRouter (works with the OOB `balanced` preset).
# export OPENROUTER_API_KEY="sk-or-v1-..."

# DeepSeek — direct API for V4 Pro / V4 Flash (best DeepSeek experience)
# export DEEPSEEK_API_KEY="..."

# Anthropic — Claude Opus / Sonnet (premium preset)
# export ANTHROPIC_API_KEY="sk-ant-..."

# Z.AI Coding Plan — GLM-5.1 + zai_vision MCP (subscription)
# export Z_AI_API_KEY="..."

# Kimi for Coding — Moonshot K2.6 (subscription, custom preset)
# export KIMI_API_KEY="..."

# OpenAI — for Whisper API transcription if you don't want local whisper.cpp
# export OPENAI_API_KEY="sk-..."

# ── Tool-specific tokens ─────────────────────────────────────────────
# Hugging Face — used by `transcribe` to download whisper.cpp models from
# huggingface.co (large-v3-turbo, ~1.6 GB). Optional: public models work
# without a token, but HF_TOKEN unlocks higher rate limits + private models.
# export HF_TOKEN="hf_..."

# Exa — used by the built-in `websearch` MCP (oh-my-opencode-slim plugin).
# Without a key, you get the free tier (limited quotas). Get one at exa.ai
# for higher daily quotas.
# export EXA_API_KEY="..."
