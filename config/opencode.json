{
  "$schema": "https://opencode.ai/config.json",
  "subagent_depth": 1,
  "instructions": [
    "~/.agents/AGENTS.md"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "includeUsage": true,
        "chunkTimeout": 60000,
        "headerTimeout": 30000,
        "timeout": false
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "reasoning": true,
          "temperature": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "options": {
            "thinking": {
              "type": "enabled"
            },
            "reasoningEffort": "max"
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "max": {
              "reasoningEffort": "max"
            },
            "non-think": {
              "thinking": {
                "type": "disabled"
              }
            }
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "reasoning": true,
          "temperature": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "options": {
            "thinking": {
              "type": "enabled"
            },
            "reasoningEffort": "max"
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "max": {
              "reasoningEffort": "max"
            },
            "non-think": {
              "thinking": {
                "type": "disabled"
              }
            }
          }
        }
      }
    },
    "kimi-for-coding": {
      "npm": "@ai-sdk/anthropic",
      "name": "Kimi for Coding",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1",
        "includeUsage": true,
        "chunkTimeout": 60000,
        "headerTimeout": 30000,
        "timeout": false
      },
      "models": {
        "kimi-k3-1m": {
          "id": "k3",
          "name": "Kimi K3 1M (Kimi Coding API)",
          "reasoning": true,
          "temperature": false,
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "attachment": true,
          "options": {
            "effort": "max"
          },
          "variants": {
            "high": {
              "disabled": true
            },
            "max": {
              "disabled": true
            }
          }
        }
      }
    },
    "zai-coding-plan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Z.AI Coding Plan",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "includeUsage": true,
        "chunkTimeout": 240000,
        "headerTimeout": 120000,
        "timeout": false
      },
      "models": {
        "glm-5.2": {
          "name": "GLM 5.2 (Z.AI)",
          "reasoning": true,
          "temperature": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 1000000,
            "output": 131072
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "clear_thinking": false
            },
            "reasoningEffort": "max"
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "max": {
              "reasoningEffort": "max"
            },
            "non-think": {
              "thinking": {
                "type": "disabled"
              }
            }
          }
        }
      }
    },
    "anthropic": {
      "name": "Anthropic",
      "options": {
        "baseURL": "https://api.anthropic.com/v1"
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          "reasoning": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "options": {
            "thinking": {
              "type": "adaptive"
            },
            "output_config": {
              "effort": "high"
            }
          },
          "variants": {
            "high": {
              "output_config": {
                "effort": "high"
              }
            },
            "max": {
              "output_config": {
                "effort": "max"
              }
            },
            "non-think": {
              "thinking": {
                "type": "disabled"
              }
            }
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "reasoning": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "options": {
            "thinking": {
              "type": "adaptive"
            },
            "output_config": {
              "effort": "high"
            }
          },
          "variants": {
            "high": {
              "output_config": {
                "effort": "high"
              }
            },
            "max": {
              "output_config": {
                "effort": "max"
              }
            },
            "non-think": {
              "thinking": {
                "type": "disabled"
              }
            }
          }
        }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "includeUsage": true,
        "chunkTimeout": 60000,
        "headerTimeout": 30000,
        "timeout": false
      },
      "models": {
        "anthropic/claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6 (via OpenRouter)",
          "reasoning": true,
          "temperature": true,
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "deepseek/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (via OpenRouter)",
          "reasoning": true,
          "temperature": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 1048576,
            "output": 32768
          },
          "options": {
            "reasoning": {
              "enabled": true
            }
          },
          "variants": {
            "high": {},
            "max": {},
            "low": {}
          }
        },
        "google/gemini-3.5-flash": {
          "name": "Gemini 3.5 Flash (via OpenRouter)",
          "reasoning": true,
          "temperature": true,
          "limit": {
            "context": 1000000,
            "output": 32768
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
              "audio"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "high": {},
            "max": {},
            "low": {}
          }
        },
        "moonshotai/kimi-k3": {
          "name": "Kimi K3 (via OpenRouter)",
          "reasoning": true,
          "temperature": false,
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "attachment": true
        },
        "nvidia/nemotron-3-super-120b-a12b:free": {
          "name": "Nemotron 3 Super Free (via OpenRouter)",
          "reasoning": true,
          "temperature": true,
          "limit": {
            "context": 32000,
            "output": 16384
          }
        },
        "qwen/qwen3-coder:free": {
          "name": "Qwen3 Coder Free (via OpenRouter)",
          "reasoning": true,
          "temperature": true,
          "limit": {
            "context": 40000,
            "output": 16384
          }
        }
      }
    },
    "openai": {
      "options": {
        "headerTimeout": false
      },
      "models": {
        "gpt-5.5": {
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          }
        },
        "gpt-5.5-fast": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 Fast (ChatGPT OAuth)",
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "options": {
            "serviceTier": "priority"
          }
        },
        "gpt-5.6-sol": {
          "limit": {
            "context": 500000,
            "input": 372000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "xhigh"
          },
          "variants": {
            "max": {
              "reasoningEffort": "max"
            }
          }
        },
        "gpt-5.6-sol-fast-high": {
          "id": "gpt-5.6-sol",
          "name": "GPT-5.6 Sol Fast High (ChatGPT OAuth)",
          "limit": {
            "context": 500000,
            "input": 372000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "high",
            "serviceTier": "priority"
          },
          "variants": {
            "max": {
              "disabled": true
            }
          }
        },
        "gpt-5.6-sol-fast": {
          "id": "gpt-5.6-sol",
          "name": "GPT-5.6 Sol Fast (ChatGPT OAuth)",
          "limit": {
            "context": 500000,
            "input": 372000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "xhigh",
            "serviceTier": "priority"
          },
          "variants": {
            "max": {
              "reasoningEffort": "max"
            }
          }
        },
        "gpt-5.6-terra": {
          "limit": {
            "context": 500000,
            "input": 372000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "xhigh"
          },
          "variants": {
            "max": {
              "reasoningEffort": "max"
            }
          }
        },
        "gpt-5.6-terra-fast": {
          "id": "gpt-5.6-terra",
          "name": "GPT-5.6 Terra Fast (ChatGPT OAuth)",
          "limit": {
            "context": 500000,
            "input": 372000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "xhigh",
            "serviceTier": "priority"
          },
          "variants": {
            "max": {
              "reasoningEffort": "max"
            }
          }
        },
        "gpt-5.6-luna": {
          "limit": {
            "context": 500000,
            "input": 372000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "xhigh"
          },
          "variants": {
            "max": {
              "reasoningEffort": "max"
            }
          }
        },
        "gpt-5.6-luna-fast": {
          "id": "gpt-5.6-luna",
          "name": "GPT-5.6 Luna Fast (ChatGPT OAuth)",
          "limit": {
            "context": 500000,
            "input": 372000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "xhigh",
            "serviceTier": "priority"
          },
          "variants": {
            "max": {
              "reasoningEffort": "max"
            }
          }
        }
      }
    }
  },
  "plugin": [
    "oh-my-opencode-slim@2.2.8"
  ],
  "mcp": {
    "zai_vision": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server@0.1.4"
      ],
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      },
      "enabled": true,
      "timeout": 600000
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      },
      "enabled": true,
      "timeout": 60000
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": {
    "clangd": {
      "command": [
        "clangd",
        "--background-index",
        "--clang-tidy"
      ],
      "extensions": [
        "c",
        "cpp",
        "h",
        "hpp",
        "cc",
        "cxx"
      ]
    },
    "typescript-language-server": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "languages": [
        "typescript",
        "typescriptreact",
        "javascript",
        "javascriptreact"
      ],
      "extensions": [
        "ts",
        "tsx",
        "js",
        "jsx"
      ]
    },
    "pyright": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ],
      "languages": [
        "python"
      ],
      "extensions": [
        "py",
        "pyi"
      ],
      "settings": {
        "python": {
          "analysis": {
            "autoSearchPaths": true,
            "useLibraryCodeForTypes": true,
            "diagnosticMode": "openFilesOnly",
            "typeCheckingMode": "standard"
          }
        }
      }
    },
    "rust-analyzer": {
      "command": [
        "rust-analyzer"
      ],
      "languages": [
        "rust"
      ],
      "extensions": [
        "rs"
      ],
      "settings": {
        "rust-analyzer": {
          "checkOnSave": {
            "command": "clippy"
          },
          "cargo": {
            "allFeatures": true
          },
          "procMacro": {
            "enable": true
          }
        }
      }
    },
    "gopls": {
      "command": [
        "gopls",
        "serve"
      ],
      "languages": [
        "go",
        "gomod"
      ],
      "extensions": [
        "go",
        "mod"
      ],
      "settings": {
        "gopls": {
          "staticcheck": true,
          "gofumpt": true,
          "analyses": {
            "unusedparams": true,
            "shadow": true
          }
        }
      }
    },
    "kotlin-language-server": {
      "command": [
        "kotlin-language-server-wrapper"
      ],
      "languages": [
        "kotlin"
      ],
      "extensions": [
        "kt",
        "kts"
      ],
      "settings": {
        "kotlin": {
          "compiler": {
            "jvm": {
              "target": "17"
            }
          },
          "indexing": {
            "enabled": true
          },
          "completion": {
            "snippets": {
              "enabled": true
            }
          },
          "diagnostics": {
            "enabled": true
          }
        }
      }
    }
  },
  "permission": "allow"
}
