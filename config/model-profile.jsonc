{
  // ── Model Profile ──────────────────────────────────────────
  // Edit this file to change agent models. Then run:
  //   oc --sync-profile
  //
  // Per-project overrides use .opencode/oh-my-opencode-slim.jsonc
  // (omo-slim reads this automatically — just set model there)

  "preset": "balanced",

  // Tmux multiplexer: live subagent panes (only active inside tmux)
  // Toggle: "auto" (enable in tmux) | "none" (disable)
  "multiplexer": {
    "type": "auto",
    "layout": "main-vertical",
    "main_pane_size": 60
  },

  "presets": {

    // ============ CUSTOM (subscriptions + DeepSeek API) ============
    "custom": {
      // For DeepSeek V4 Pro as primary model, use the "deepseek" preset below.
      "orchestrator": { "model": "zai-coding-plan/glm-5.1", "variant": "max", "temperature": 0.8 },
      "oracle":       { "model": "zai-coding-plan/glm-5.1", "variant": "max", "temperature": 1.0 },
      "explorer":     { "model": "zai-coding-plan/glm-5.1", "variant": "max", "temperature": 0.8 },
      "librarian":    { "model": "zai-coding-plan/glm-5.1", "variant": "max", "temperature": 0.8 },
      "fixer":        { "model": "kimi-for-coding/kimi-for-coding", "variant": "max", "thinking": 65536, "temperature": 1.0 },
      // Gemini Pro/Flash via OpenRouter: variant system returns {} for these models
      // (only gemini-3 gets variants). No variant needed — designer/observer don't use reasoning.
      "designer":     { "model": "openrouter/~google/gemini-pro-latest", "temperature": 1.0 },
      "observer":     { "model": "openrouter/~google/gemini-pro-latest", "temperature": 1.0 },
      "council":      { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 }
    },

    // ============ BALANCED (OpenRouter-only, works with just one API key) ============
    "balanced": {
      "orchestrator": { "model": "openrouter/z-ai/glm-5.1", "variant": "high", "temperature": 0.8 },
      "oracle":       { "model": "openrouter/z-ai/glm-5.1", "variant": "high", "temperature": 1.0 },
      "designer":     { "model": "openrouter/~google/gemini-flash-latest", "temperature": 1.0 },
      "explorer":     { "model": "openrouter/deepseek/deepseek-v3.2", "variant": "high", "temperature": 0.7 },
      "librarian":    { "model": "openrouter/qwen/qwen3.6-plus", "variant": "high", "temperature": 0.7 },
      "fixer":        { "model": "openrouter/deepseek/deepseek-v3.2", "variant": "high", "temperature": 0.7 },
      "observer":     { "model": "openrouter/~google/gemini-flash-latest", "temperature": 1.0 },
      "council":      { "model": "openrouter/qwen/qwen3.6-plus", "variant": "high", "temperature": 0.7 }
    },

    // ============ PREMIUM (best available, no cost concern) ============
    "premium": {
      "orchestrator": { "model": "anthropic/claude-opus-4-7", "variant": "max", "temperature": 0.6 },
      "oracle":       { "model": "anthropic/claude-opus-4-7", "variant": "max", "temperature": 1.0 },
      "designer":     { "model": "openrouter/~google/gemini-pro-latest", "temperature": 1.0 },
      "explorer":     { "model": "anthropic/claude-sonnet-4-6", "variant": "high", "temperature": 0.6 },
      "librarian":    { "model": "anthropic/claude-sonnet-4-6", "variant": "high", "temperature": 0.6 },
      "fixer":        { "model": "anthropic/claude-sonnet-4-6", "variant": "high", "temperature": 0.6 },
      "observer":     { "model": "openrouter/~google/gemini-pro-latest", "temperature": 1.0 },
      "council":      { "model": "anthropic/claude-opus-4-7", "variant": "max", "temperature": 1.0 }
    },

    // ============ DEEPSEEK (pure DeepSeek V4 Pro + Gemini multimodal) ============
    "deepseek": {
      "orchestrator": { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 0.8 },
      "oracle":       { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 },
      "explorer":     { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 0.8 },
      "librarian":    { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 0.8 },
      "fixer":        { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 0.8 },
      "designer":     { "model": "openrouter/~google/gemini-pro-latest", "temperature": 1.0 },
      "observer":     { "model": "openrouter/~google/gemini-pro-latest", "temperature": 1.0 },
      "council":      { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 }
    },

    // ============ CHEAP (budget-optimized, free models where possible) ============
    "cheap": {
      "orchestrator": { "model": "openrouter/qwen/qwen3-coder", "variant": "high", "temperature": 0.7 },
      "oracle":       { "model": "openrouter/qwen/qwen3.6-plus", "variant": "high", "temperature": 1.0 },
      "designer":     { "model": "openrouter/~google/gemini-flash-latest", "temperature": 1.0 },
      "explorer":     { "model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free", "variant": "high", "temperature": 1.0 },
      "librarian":    { "model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free", "variant": "high", "temperature": 1.0 },
      "fixer":        { "model": "openrouter/deepseek/deepseek-v3.2", "variant": "high", "temperature": 0.7 },
      "observer":     { "model": "openrouter/~google/gemini-flash-latest", "temperature": 1.0 },
      "council":      { "model": "openrouter/qwen/qwen3.6-plus", "variant": "high", "temperature": 0.7 }
    },

    // ============ OPENAI (ChatGPT Plus OAuth via /connect) ============
    "openai": {
      "orchestrator": { "model": "openai/gpt-5.5", "variant": "xhigh", "temperature": 0.8 },
      "oracle":       { "model": "openai/gpt-5.5", "variant": "xhigh", "temperature": 1.0 },
      "librarian":    { "model": "openai/gpt-5.4", "variant": "xhigh", "temperature": 0.8 },
      // Codex models for code-heavy agents — purpose-built beats general-purpose
      "explorer":     { "model": "openai/gpt-5.3-codex", "variant": "high", "temperature": 0.8 },
      "fixer":        { "model": "openai/gpt-5.3-codex", "variant": "high", "temperature": 1.0 },
      // Gemini for vision — Codex endpoint doesn't reliably support vision
      "designer":     { "model": "openrouter/~google/gemini-pro-latest", "temperature": 1.0 },
      "observer":     { "model": "openrouter/~google/gemini-pro-latest", "temperature": 1.0 },
      "council":      { "model": "openai/gpt-5.5", "variant": "xhigh", "temperature": 1.0 }
    }
  },

  // ── Council Reviewers ────────────────────────────────────────
  // (the council chair/synthesis agent is configured in presets.<preset>.council above)
  // Each preset lists reviewer models for @council multi-LLM consensus.
  // Supported per-reviewer: model (required), variant (optional), prompt (optional).
  // Temperature is hardcoded to 0.2 by omo-slim (councillor.ts:67).
  // Thinking/options are NOT supported per-reviewer — the generator strips
  // unknown keys; Zod does the same at runtime as a second line of defense.
  // If a preset is omitted here, hardcoded defaults in model-profile.py are used.
  "council": {
    "councillor_execution_mode": "parallel",
    "presets": {
      "custom": {
        "reviewer-1": { "model": "kimi-for-coding/kimi-for-coding" },
        "reviewer-2": { "model": "openrouter/qwen/qwen3.6-plus" },
        "reviewer-3": { "model": "openrouter/anthropic/claude-sonnet-4.6" }
      },
      "balanced": {
        "reviewer-1": { "model": "openrouter/z-ai/glm-5.1" },
        "reviewer-2": { "model": "openrouter/qwen/qwen3.6-plus" }
      },
      "premium": {
        "reviewer-1": { "model": "anthropic/claude-sonnet-4-6" },
        "reviewer-2": { "model": "openrouter/z-ai/glm-5.1" },
        "reviewer-3": { "model": "openrouter/google/gemini-3.1-pro-preview" }
      },
      "deepseek": {
        "reviewer-1": { "model": "kimi-for-coding/kimi-for-coding" },
        "reviewer-2": { "model": "openrouter/z-ai/glm-5.1" },
        "reviewer-3": { "model": "openrouter/anthropic/claude-sonnet-4.6" }
      },
      "cheap": {
        "reviewer-1": { "model": "openrouter/qwen/qwen3-coder" },
        "reviewer-2": { "model": "openrouter/qwen/qwen3.6-plus" },
        "reviewer-3": { "model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free" }
      },
      "openai": {
        "reviewer-1": { "model": "zai-coding-plan/glm-5.1" },
        "reviewer-2": { "model": "openrouter/anthropic/claude-sonnet-4.6" },
        "reviewer-3": { "model": "deepseek/deepseek-v4-pro" }
      }
    }
  }
}
