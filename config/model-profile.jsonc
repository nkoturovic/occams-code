{
  // ── Model Profile ──────────────────────────────────────────
  // Edit this file to change agent models. Then run:
  //   oc --sync-profile
  //
  // Per-project overrides use .opencode/oh-my-opencode-slim.jsonc
  // (omo-slim reads this automatically — just set model there)

  "preset": "balanced",

  // Multiplexer: live subagent panes (active inside tmux, Zellij, or Herdr)
  // Toggle: "auto" (detect tmux/zellij/herdr) | "tmux" | "zellij" | "herdr" | "none"
  "multiplexer": {
    "type": "auto",
    "layout": "main-vertical",
    "main_pane_size": 60
  },

  "presets": {

    // ============ CUSTOM (subscriptions + DeepSeek API) ============
    "custom": {
      // For DeepSeek V4 Pro as primary model, use the "deepseek" preset below.
      "orchestrator": { "model": "zai-coding-plan/glm-5.2", "variant": "max", "temperature": 0.8 },
      // DO NOT DELETE: original GLM-5.2 oracle config for easy fallback
      // "oracle":       { "model": "zai-coding-plan/glm-5.2", "variant": "max", "temperature": 1.0 },
      // DO NOT DELETE: DeepSeek V4 Pro oracle config for easy fallback
      // "oracle":       { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 },
      "oracle":       { "model": "openai/gpt-5.6-sol", "variant": "max", "temperature": 1.0 },
      "explorer":    { "model": "openai/gpt-5.6-terra", "variant": "xhigh", "temperature": 0.8 },
      // Librarian: GLM-5.2 has no xhigh; max is its highest effort. Terra is fallback #1.
      "librarian":    { "model": "zai-coding-plan/glm-5.2", "variant": "max", "temperature": 0.8 },
      "fixer":        { "model": "zai-coding-plan/glm-5.2", "variant": "max", "temperature": 0.8 },
      // Kimi K3 via subscription: text+image, intrinsic max effort, no temperature.
      "designer":     { "model": "kimi-for-coding/kimi-k3-1m", "variant": null },
      "observer":     { "model": "kimi-for-coding/kimi-k3-1m", "variant": null },
      "council":      { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 }
    },

    // ============ BALANCED (OpenRouter-only, best cost/quality) ============
    "balanced": {
      "orchestrator": { "model": "openrouter/deepseek/deepseek-v4-pro", "temperature": 0.8 },
      "oracle":       { "model": "openrouter/deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 },
      "designer":     { "model": "openrouter/google/gemini-3.5-flash", "temperature": 1.0 },
      "explorer":     { "model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free", "temperature": 1.0 },
      "librarian":    { "model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free", "temperature": 1.0 },
      "fixer":        { "model": "openrouter/deepseek/deepseek-v4-pro", "temperature": 0.7 },
      "observer":     { "model": "openrouter/google/gemini-3.5-flash", "temperature": 1.0 },
      "council":      { "model": "openrouter/deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 }
    },

    // ============ PREMIUM (best available, no cost concern) ============
    "premium": {
      "orchestrator": { "model": "anthropic/claude-opus-4-7", "variant": "max", "temperature": 0.6 },
      "oracle":       { "model": "anthropic/claude-opus-4-7", "variant": "max", "temperature": 1.0 },
      "designer":     { "model": "openrouter/google/gemini-3.5-flash", "temperature": 1.0 },
      "explorer":     { "model": "anthropic/claude-sonnet-4-6", "variant": "high", "temperature": 0.6 },
      "librarian":    { "model": "anthropic/claude-sonnet-4-6", "variant": "high", "temperature": 0.6 },
      "fixer":        { "model": "anthropic/claude-sonnet-4-6", "variant": "high", "temperature": 0.6 },
      "observer":     { "model": "openrouter/google/gemini-3.5-flash", "temperature": 1.0 },
      "council":      { "model": "anthropic/claude-opus-4-7", "variant": "max", "temperature": 1.0 }
    },

    // ============ DEEPSEEK (DeepSeek V4 Pro for reasoning-heavy roles) ============
    "deepseek": {
      "orchestrator": { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 0.8 },
      "oracle":       { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 },
      "explorer":     { "model": "zai-coding-plan/glm-5.2", "variant": "max", "temperature": 0.8 },
      "librarian":    { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 0.8 },
      "fixer":        { "model": "zai-coding-plan/glm-5.2", "variant": "max", "temperature": 0.8 },
      "designer":     { "model": "openrouter/google/gemini-3.5-flash", "temperature": 1.0 },
      "observer":     { "model": "openrouter/google/gemini-3.5-flash", "temperature": 1.0 },
      "council":      { "model": "deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 }
    },

    // ============ CHEAP (OpenRouter-only, free models where possible) ============
    "cheap": {
      "orchestrator": { "model": "openrouter/qwen/qwen3-coder:free", "temperature": 0.7 },
      "oracle":       { "model": "openrouter/deepseek/deepseek-v4-pro", "variant": "max", "temperature": 1.0 },
      "designer":     { "model": "openrouter/google/gemini-3.5-flash", "temperature": 1.0 },
      "explorer":     { "model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free", "variant": "high", "temperature": 1.0 },
      "librarian":    { "model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free", "variant": "high", "temperature": 1.0 },
      "fixer":        { "model": "openrouter/qwen/qwen3-coder:free", "temperature": 0.7 },
      "observer":     { "model": "openrouter/google/gemini-3.5-flash", "temperature": 1.0 },
      "council":      { "model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free", "temperature": 1.0 }
    },

    // ============ OPENAI (ChatGPT Plus OAuth via /connect) ============
    "openai": {
      "orchestrator": { "model": "openai/gpt-5.6-sol", "variant": "xhigh", "temperature": 0.8 },
      // "orchestrator": { "model": "zai-coding-plan/glm-5.2", "variant": "max", "temperature": 0.8 },
      "oracle":       { "model": "openai/gpt-5.6-sol", "variant": "max", "temperature": 1.0 },
      "librarian":    { "model": "openai/gpt-5.6-terra", "variant": "xhigh", "temperature": 0.8 },
      "explorer":     { "model": "openai/gpt-5.6-terra", "variant": "xhigh", "temperature": 0.8 },
      "fixer":        { "model": "openai/gpt-5.6-sol", "variant": "xhigh", "temperature": 0.8 },
      // Terra supports text/image via OAuth; Kimi/Gemini remain multimodal fallbacks.
      "designer":     { "model": "openai/gpt-5.6-terra", "variant": "xhigh", "temperature": 1.0 },
      "observer":     { "model": "openai/gpt-5.6-terra", "variant": "xhigh", "temperature": 1.0 },
      "council":      { "model": "openai/gpt-5.6-sol", "variant": "max", "temperature": 1.0 }
    },

    // ============ OPENAI FAST (ChatGPT Plus OAuth Priority tier) ============
    "openai-fast": {
      "orchestrator": { "model": "openai/gpt-5.6-sol-fast", "variant": "xhigh", "temperature": 0.8 },
      "oracle":       { "model": "openai/gpt-5.6-sol-fast", "variant": "max", "temperature": 1.0 },
      "librarian":    { "model": "openai/gpt-5.6-terra-fast", "variant": "xhigh", "temperature": 0.8 },
      "explorer":     { "model": "openai/gpt-5.6-terra-fast", "variant": "xhigh", "temperature": 0.8 },
      "fixer":        { "model": "openai/gpt-5.6-sol-fast", "variant": "xhigh", "temperature": 0.8 },
      // Terra supports text/image via OAuth; Kimi/Gemini remain multimodal fallbacks.
      "designer":     { "model": "openai/gpt-5.6-terra-fast", "variant": "xhigh", "temperature": 1.0 },
      "observer":     { "model": "openai/gpt-5.6-terra-fast", "variant": "xhigh", "temperature": 1.0 },
      "council":      { "model": "openai/gpt-5.6-sol-fast", "variant": "max", "temperature": 1.0 }
    },

    // ============ KIMI (declared 1M/128K metadata expected with entitlement; no >262K local proof) ============
    "kimi": {
      // Explicit null omits the top-level variant; K3 max effort is model-level.
      "orchestrator": { "model": "kimi-for-coding/kimi-k3-1m", "variant": null },
      "oracle":       { "model": "openai/gpt-5.5-fast", "variant": "xhigh", "temperature": 0.2 },
      "librarian":    { "model": "openai/gpt-5.6-sol-fast", "variant": "high", "temperature": 0.2 },
      "explorer":     { "model": "openai/gpt-5.6-sol-fast", "variant": "high", "temperature": 0.1 },
      "fixer":        { "model": "openai/gpt-5.6-sol-fast", "variant": "high", "temperature": 0.2 },
      "designer":     { "model": "openai/gpt-5.6-sol-fast", "variant": "high", "temperature": 0.4 },
      "observer":     { "model": "openai/gpt-5.6-sol-fast", "variant": "high", "temperature": 0.2 },
      "council":      { "model": "openai/gpt-5.6-sol-fast", "variant": "high", "temperature": 0.2 }
    }
  },

  // ── Council Reviewers ────────────────────────────────────────
  // (the council chair/synthesis agent is configured in presets.<preset>.council above)
  // Each preset lists reviewer models for @council multi-LLM consensus.
  // Supported per-reviewer: model string or ordered fallback array (required),
  // variant (optional), prompt (optional). Array entries may be model strings
  // or { "id": "provider/model", "variant": "..." } objects (v2.1.1+).
  // Temperature is hardcoded to 0.2 by omo-slim (councillor.ts:67).
  // Thinking/options are NOT supported per-reviewer — the generator strips
  // unknown keys; Zod does the same at runtime as a second line of defense.
  // If a preset is omitted here, hardcoded defaults in model-profile.py are used.
  "council": {
    "presets": {
      "custom": {
        "reviewer-1": { "model": "zai-coding-plan/glm-5.2", "variant": "max" },
        "reviewer-2": { "model": "openai/gpt-5.6-sol", "variant": "xhigh" },
        "reviewer-3": { "model": "openrouter/anthropic/claude-sonnet-4.6" }
      },
      "balanced": {
        "reviewer-1": { "model": "openrouter/deepseek/deepseek-v4-pro" },
        "reviewer-2": { "model": "openrouter/anthropic/claude-sonnet-4.6" }
      },
      "premium": {
        "reviewer-1": { "model": "anthropic/claude-sonnet-4-6" },
        "reviewer-2": { "model": "openrouter/anthropic/claude-sonnet-4.6" },
        "reviewer-3": { "model": "openrouter/google/gemini-3.5-flash" }
      },
      "deepseek": {
        "reviewer-1": { "model": "kimi-for-coding/kimi-k3-1m" },
        "reviewer-2": { "model": "openrouter/deepseek/deepseek-v4-pro" },
        "reviewer-3": { "model": "openrouter/anthropic/claude-sonnet-4.6" }
      },
      "cheap": {
        "reviewer-1": { "model": "openrouter/qwen/qwen3-coder:free" },
        "reviewer-2": { "model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free" }
      },
      "openai": {
        "reviewer-1": { "model": "zai-coding-plan/glm-5.2", "variant": "max" },
        "reviewer-2": { "model": "openrouter/anthropic/claude-sonnet-4.6", "variant": "high" },
        "reviewer-3": { "model": "deepseek/deepseek-v4-pro", "variant": "max" }
      },
      "openai-fast": {
        "reviewer-1": { "model": "zai-coding-plan/glm-5.2", "variant": "max" },
        "reviewer-2": { "model": "openrouter/anthropic/claude-sonnet-4.6", "variant": "high" },
        "reviewer-3": { "model": "deepseek/deepseek-v4-pro", "variant": "max" }
      },
      "kimi": {
        "reviewer-1": { "model": "kimi-for-coding/kimi-k3-1m" },
        "reviewer-2": { "model": "openai/gpt-5.5-fast", "variant": "xhigh" },
        "reviewer-3": { "model": "deepseek/deepseek-v4-pro", "variant": "max" }
      }
    }
  }
}
